rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // Global Static Deny
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // Reusable Helpers
    // -------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidId(id) {
      return id is string
        && id.size() <= 128
        && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incomingData() {
      return request.resource.data;
    }

    function existingData() {
      return resource.data;
    }

    function ideaPath(ideaId) {
      return /databases/$(database)/documents/ideas/$(ideaId);
    }

    function ideaDoc(ideaId) {
      return get(ideaPath(ideaId));
    }

    function ideaExists(ideaId) {
      return exists(ideaPath(ideaId));
    }

    function isIdeaReadable(ideaId) {
      return ideaExists(ideaId) && (
        !('visibility' in ideaDoc(ideaId).data) ||
        ideaDoc(ideaId).data.visibility == 'public' ||
        isOwner(ideaDoc(ideaId).data.authorId) ||
        (isSignedIn() && ('supportedBy' in ideaDoc(ideaId).data) && (request.auth.uid in ideaDoc(ideaId).data.supportedBy))
      );
    }

    function isValidVisibility(v) {
      return v in ['public', 'unlisted', 'private'];
    }

    function isValidIdeaType(v) {
      return v in ['seed', 'sprout'];
    }

    function isValidIdeaStage(v) {
      return v in ['seed', 'sprout', 'growing', 'testing', 'launching', 'released', 'archived'];
    }

    function isValidProjectStage(v) {
      return !(v is string) || v in ['idea', 'prototype', 'beta', 'in_dev'];
    }

    // -------------------------------------------------------------------------
    // User Profiles
    // -------------------------------------------------------------------------
    match /users/{userId} {
      allow read: if true; // Public profiles are fine in this community-focused app

      allow create: if isOwner(userId) &&
        incomingData().keys().hasAll(['name', 'role', 'plan', 'createdAt']) &&
        incomingData().role == 'user' &&
        incomingData().plan == 'free' &&
        incomingData().name is string &&
        incomingData().name.size() <= 120 &&
        incomingData().createdAt is timestamp;

      allow update: if isOwner(userId) &&
        incomingData().diff(existingData()).affectedKeys().hasOnly([
          'name',
          'avatarUrl',
          'bio',
          'skills',
          'socialLinks',
          'aiTicketBalance',
          'updatedAt'
        ]) &&
        (!('name' in incomingData()) || (incomingData().name is string && incomingData().name.size() <= 120)) &&
        (!('avatarUrl' in incomingData()) || (incomingData().avatarUrl is string && incomingData().avatarUrl.size() <= 250000)) &&
        (!('bio' in incomingData()) || (incomingData().bio is string && incomingData().bio.size() <= 1000)) &&
        (!('skills' in incomingData()) || (incomingData().skills is list && incomingData().skills.size() <= 20)) &&
        (!('plan' in incomingData()) || incomingData().plan in ['free', 'supporter', 'pro']) &&
        (!('aiTicketBalance' in incomingData()) || incomingData().aiTicketBalance is number);
    }

    // -------------------------------------------------------------------------
    // Salon / Greenhouse
    // -------------------------------------------------------------------------
    function isBetaGreenhouseMember() {
      return isSignedIn();
    }

    match /salonPosts/{postId} {
      allow read: if isBetaGreenhouseMember();
      
      allow create: if isBetaGreenhouseMember() &&
        incomingData().authorId == request.auth.uid &&
        incomingData().authorPlan in ['free', 'supporter', 'pro'] &&
        incomingData().boostState == 'none' &&
        incomingData().cheerCount == 0 &&
        incomingData().commentCount == 0 &&
        incomingData().createdAt is timestamp &&
        incomingData().title is string &&
        incomingData().title.size() > 0 &&
        incomingData().title.size() <= 120 &&
        incomingData().body is string &&
        incomingData().body.size() > 0 &&
        incomingData().body.size() <= 2000;

      allow update: if (isOwner(existingData().authorId) && 
        incomingData().authorId == existingData().authorId &&
        incomingData().createdAt == existingData().createdAt &&
        incomingData().diff(existingData()).affectedKeys().hasOnly(['boostState', 'updatedAt', 'title', 'body', 'screenshotUrl']) &&
        (!('boostState' in incomingData()) || incomingData().boostState in ['none', 'applied']) &&
        (!('title' in incomingData()) || (incomingData().title is string && incomingData().title.size() > 0 && incomingData().title.size() <= 120)) &&
        (!('body' in incomingData()) || (incomingData().body is string && incomingData().body.size() > 0 && incomingData().body.size() <= 2000))
      ) || (
        isSignedIn() &&
        incomingData().diff(existingData()).affectedKeys().hasOnly(['cheerCount', 'commentCount'])
      );

      allow delete: if isOwner(existingData().authorId);
    }

    match /salonComments/{commentId} {
      allow read: if isBetaGreenhouseMember();
      allow create: if isBetaGreenhouseMember() &&
        incomingData().authorId == request.auth.uid &&
        incomingData().createdAt is timestamp &&
        incomingData().body is string &&
        incomingData().body.size() > 0 &&
        incomingData().body.size() <= 1000 &&
        incomingData().authorPlan in ['free', 'supporter', 'pro'];
      allow delete: if isOwner(existingData().authorId);
    }

    match /salonReactions/{reactionId} {
      // reactionId = {postId}_{userId}
      allow read: if isBetaGreenhouseMember();
      allow create, delete: if isBetaGreenhouseMember() &&
        reactionId == incomingData().postId + '_' + request.auth.uid &&
        incomingData().userId == request.auth.uid;
    }

    // -------------------------------------------------------------------------
    // Commerce
    // -------------------------------------------------------------------------
    match /purchases/{purchaseId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isEmailVerified() && isValidId(purchaseId) && incomingData().userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) && 
        incomingData().diff(existingData()).affectedKeys().hasOnly(['status', 'updatedAt']);
    }

    // -------------------------------------------------------------------------
    // AI Reports
    // -------------------------------------------------------------------------
    match /aiReports/{reportId} {
      allow get: if isOwner(resource.data.userId) || isIdeaReadable(resource.data.postId);
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isIdeaReadable(resource.data.postId));
      allow create: if isEmailVerified() 
        && incomingData().userId == request.auth.uid
        && isIdeaReadable(incomingData().postId);
    }

    // -------------------------------------------------------------------------
    // Ideas
    // -------------------------------------------------------------------------
    function isValidIdea(data) {
      return isValidIdeaType(data.type) &&
        isValidIdeaStage(data.stage) &&
        isValidVisibility(data.visibility) &&
        data.title is string &&
        data.title.size() > 0 &&
        data.title.size() <= 100 &&
        data.oneLineSummary is string &&
        data.oneLineSummary.size() > 0 &&
        data.oneLineSummary.size() <= 200 &&
        data.authorId == request.auth.uid &&
        data.createdAt is timestamp &&
        data.updatedAt is timestamp &&
        (!('description' in data) || (data.description is string && data.description.size() <= 5000)) &&
        (!('statusNote' in data) || (data.statusNote is string && data.statusNote.size() <= 280)) &&
        (!('projectStage' in data) || isValidProjectStage(data.projectStage)) &&
        (!('demoUrl' in data) || (data.demoUrl is string && data.demoUrl.size() <= 2000)) &&
        (!('repoUrl' in data) || (data.repoUrl is string && data.repoUrl.size() <= 2000));
    }

    match /ideas/{ideaId} {
      allow get, list: if !('visibility' in resource.data) 
        || resource.data.visibility == 'public' 
        || isOwner(resource.data.authorId)
        || (isSignedIn() && ('supportedBy' in resource.data) && (request.auth.uid in resource.data.supportedBy));

      allow create: if isEmailVerified() &&
        isValidId(ideaId) &&
        isValidIdea(incomingData()) &&
        incomingData().keys().hasAll([
          'type',
          'stage',
          'title',
          'oneLineSummary',
          'authorId',
          'createdAt',
          'updatedAt',
          'supportCount',
          'commentCount',
          'releaseStatus',
          'visibility',
          'supportedBy',
          'builderReactionCount'
        ]) &&
        incomingData().supportCount == 0 &&
        incomingData().commentCount == 0 &&
        incomingData().builderReactionCount == 0 &&
        incomingData().releaseStatus == 'none' &&
        (!('releasedAt' in incomingData()) || incomingData().releasedAt == null) &&
        (!('latestReleaseId' in incomingData()) || incomingData().latestReleaseId == null) &&
        (!('rootIdeaId' in incomingData()) || incomingData().rootIdeaId == null || incomingData().rootIdeaId is string) &&
        (!('parentIdeaId' in incomingData()) || incomingData().parentIdeaId == null || incomingData().parentIdeaId is string);

      allow update: if (isOwner(existingData().authorId) &&
        isValidIdea(incomingData()) &&
        // immutable fields
        incomingData().authorId == existingData().authorId &&
        incomingData().createdAt == existingData().createdAt &&
        incomingData().supportCount == existingData().supportCount &&
        incomingData().commentCount == existingData().commentCount &&
        incomingData().builderReactionCount == existingData().builderReactionCount &&
        incomingData().latestReleaseId == existingData().latestReleaseId &&
        incomingData().releasedAt == existingData().releasedAt &&
        incomingData().rootIdeaId == existingData().rootIdeaId &&
        // only allow intended client-editable fields
        incomingData().diff(existingData()).affectedKeys().hasOnly([
          'stage',
          'title',
          'oneLineSummary',
          'description',
          'statusNote',
          'projectStage',
          'demoUrl',
          'repoUrl',
          'tags',
          'visibility',
          'updatedAt',
          'releaseStatus',
          'parentIdeaId',
          'struggles',
          'whatItDoes',
          'targetUsers',
          'currentStatus',
          'lookingFor',
          'testerCall',
          'screenshots',
          'updatedAt'
        ])) || (
          // Allow admins to hide/review public UGC without changing authorship.
          isAdmin() &&
          incomingData().authorId == existingData().authorId &&
          incomingData().createdAt == existingData().createdAt &&
          incomingData().diff(existingData()).affectedKeys().hasOnly([
            'visibility',
            'moderationState',
            'moderationReason',
            'moderatedAt',
            'moderatedBy',
            'updatedAt'
          ]) &&
          incomingData().visibility in ['public', 'unlisted', 'private'] &&
          (!('moderationState' in incomingData()) || incomingData().moderationState in ['visible', 'hidden', 'reviewed']) &&
          (!('moderationReason' in incomingData()) || incomingData().moderationReason is string) &&
          (!('moderatedBy' in incomingData()) || incomingData().moderatedBy == request.auth.uid) &&
          (!('moderatedAt' in incomingData()) || incomingData().moderatedAt is timestamp) &&
          (!('updatedAt' in incomingData()) || incomingData().updatedAt is timestamp)
        ) || (
          // Allow anyone to increment testerCount
          isSignedIn() &&
          incomingData().diff(existingData()).affectedKeys().hasOnly(['testerCount', 'updatedAt']) &&
          incomingData().testerCount == existingData().testerCount + 1 &&
          incomingData().updatedAt is timestamp
        ) || (
          // Allow anyone to support/unsupport if they are logged in
          isSignedIn() &&
          incomingData().diff(existingData()).affectedKeys().hasOnly(['supportCount', 'supportedBy']) &&
          incomingData().supportCount is number &&
          (incomingData().supportCount == existingData().supportCount + 1 || incomingData().supportCount == existingData().supportCount - 1) &&
          incomingData().supportedBy is list
        ) || (
          // Allow anyone to increment commentCount
          isSignedIn() &&
          incomingData().diff(existingData()).affectedKeys().hasOnly(['commentCount']) &&
          incomingData().commentCount == existingData().commentCount + 1
        );

      allow delete: if isOwner(resource.data.authorId) || isAdmin();

      // -------------------------------------------------------------------------
      // Comments (Nested)
      // -------------------------------------------------------------------------
      match /comments/{commentId} {
        allow read: if isIdeaReadable(ideaId);

        allow create: if isEmailVerified() &&
          isValidId(commentId) &&
          ideaExists(ideaId) &&
          ideaDoc(ideaId).data.visibility == 'public' &&
          incomingData().ideaId == ideaId &&
          incomingData().authorId == request.auth.uid &&
          incomingData().text is string &&
          incomingData().text.size() > 0 &&
          incomingData().text.size() <= 1000 &&
          incomingData().createdAt is timestamp &&
          (!('updatedAt' in incomingData()) || incomingData().updatedAt == null || incomingData().updatedAt is timestamp) &&
          (!('kind' in incomingData()) || incomingData().kind in ['comment', 'suggestion', 'question', 'support']) &&
          (!('adoptedInRelease' in incomingData()) || incomingData().adoptedInRelease == false) &&
          (!('adoptedInMilestone' in incomingData()) || incomingData().adoptedInMilestone == false);

        allow update: if isOwner(existingData().authorId) &&
          incomingData().ideaId == existingData().ideaId &&
          incomingData().authorId == existingData().authorId &&
          incomingData().createdAt == existingData().createdAt &&
          incomingData().diff(existingData()).affectedKeys().hasOnly([
            'text',
            'updatedAt'
          ]) &&
          incomingData().text is string &&
          incomingData().text.size() > 0 &&
          incomingData().text.size() <= 1000 &&
          (!('updatedAt' in incomingData()) || incomingData().updatedAt is timestamp);

        allow delete: if isOwner(resource.data.authorId);
      }

      // -------------------------------------------------------------------------
      // Growth Events (Nested)
      // -------------------------------------------------------------------------
      match /growthEvents/{eventId} {
        allow read: if isIdeaReadable(ideaId);

        allow create: if isOwner(ideaDoc(ideaId).data.authorId) &&
          isValidId(eventId) &&
          incomingData().ideaId == ideaId &&
          incomingData().type in [
            'created_seed',
            'created_sprout',
            'commented',
            'adopted',
            'started_building',
            'opened_test',
            'beta_released',
            'released',
            'milestone',
            'status_changed'
          ] &&
          incomingData().title is string &&
          incomingData().title.size() > 0 &&
          incomingData().title.size() <= 120 &&
          (!('body' in incomingData()) || (incomingData().body is string && incomingData().body.size() <= 2000)) &&
          incomingData().createdAt is timestamp;

        allow update: if isOwner(ideaDoc(ideaId).data.authorId) &&
          incomingData().ideaId == existingData().ideaId &&
          incomingData().createdAt == existingData().createdAt;

        allow delete: if isOwner(ideaDoc(ideaId).data.authorId);
      }

      // -------------------------------------------------------------------------
      // Testers (Nested)
      // -------------------------------------------------------------------------
      match /testers/{testerId} {
        allow read: if isOwner(ideaDoc(ideaId).data.authorId) || isOwner(resource.data.userId);

        allow create: if isEmailVerified() &&
          isValidId(testerId) &&
          ideaExists(ideaId) &&
          isIdeaReadable(ideaId) &&
          ideaDoc(ideaId).data.stage == 'testing' &&
          ('testerCall' in ideaDoc(ideaId).data) &&
          request.auth.uid != ideaDoc(ideaId).data.authorId &&
          incomingData().keys().hasOnly([
            'userId',
            'userName',
            'email',
            'appliedAt',
            'status'
          ]) &&
          incomingData().userId == request.auth.uid &&
          incomingData().userName is string &&
          incomingData().userName.size() > 0 &&
          incomingData().userName.size() <= 120 &&
          incomingData().email is string &&
          incomingData().email.size() <= 320 &&
          incomingData().appliedAt is timestamp &&
          incomingData().status == 'pending';
      }
    }

    // -------------------------------------------------------------------------
    // Releases
    // -------------------------------------------------------------------------
    match /releases/{releaseId} {
      allow read, list: if resource.data.visibility == 'public' 
        || isOwner(resource.data.authorId)
        || (('ideaId' in resource.data) && isIdeaReadable(resource.data.ideaId));

      allow create: if isEmailVerified() &&
        isValidId(releaseId) &&
        incomingData().ideaId is string &&
        ideaExists(incomingData().ideaId) &&
        isOwner(ideaDoc(incomingData().ideaId).data.authorId) &&
        incomingData().authorId == request.auth.uid &&
        incomingData().status in ['planned', 'beta', 'released', 'paused'] &&
        isValidVisibility(incomingData().visibility) &&
        incomingData().createdAt is timestamp &&
        incomingData().updatedAt is timestamp &&
        (!('releasedAt' in incomingData()) || incomingData().releasedAt == null || incomingData().releasedAt is timestamp) &&
        (!('title' in incomingData()) || (incomingData().title is string && incomingData().title.size() <= 120)) &&
        (!('subtitle' in incomingData()) || (incomingData().subtitle is string && incomingData().subtitle.size() <= 280)) &&
        (!('message' in incomingData()) || (incomingData().message is string && incomingData().message.size() <= 2000)) &&
        incomingData().channels is list &&
        incomingData().channels.size() > 0 &&
        incomingData().channels.size() <= 5;

      allow update: if isOwner(existingData().authorId) &&
        ideaExists(existingData().ideaId) &&
        isOwner(ideaDoc(existingData().ideaId).data.authorId) &&
        incomingData().authorId == existingData().authorId &&
        incomingData().ideaId == existingData().ideaId &&
        incomingData().createdAt == existingData().createdAt &&
        incomingData().status in ['planned', 'beta', 'released', 'paused'] &&
        isValidVisibility(incomingData().visibility) &&
        incomingData().updatedAt is timestamp &&
        (!('releasedAt' in incomingData()) || incomingData().releasedAt == null || incomingData().releasedAt is timestamp) &&
        (!('title' in incomingData()) || (incomingData().title is string && incomingData().title.size() <= 120)) &&
        (!('subtitle' in incomingData()) || (incomingData().subtitle is string && incomingData().subtitle.size() <= 280)) &&
        (!('message' in incomingData()) || (incomingData().message is string && incomingData().message.size() <= 2000)) &&
        incomingData().channels is list &&
        incomingData().channels.size() > 0 &&
        incomingData().channels.size() <= 5;

      allow delete: if isOwner(existingData().authorId) &&
        ideaExists(existingData().ideaId) &&
        isOwner(ideaDoc(existingData().ideaId).data.authorId);
    }

    // -------------------------------------------------------------------------
    // Notifications
    // -------------------------------------------------------------------------
    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isSignedIn(); // Allow people to notify others
      allow update: if isOwner(resource.data.userId) &&
        incomingData().diff(existingData()).affectedKeys().hasOnly(['read']);
      allow delete: if isOwner(resource.data.userId);
    }

    match /contentReports/{reportId} {
      allow create: if isSignedIn() &&
        incomingData().reporterId == request.auth.uid &&
        incomingData().targetType in ['idea', 'comment', 'profile', 'salonPost'] &&
        incomingData().targetId is string &&
        incomingData().targetId.size() > 0 &&
        incomingData().targetId.size() <= 128 &&
        incomingData().reason in ['spam', 'abuse', 'illegal', 'off_topic', 'other'] &&
        incomingData().status == 'open' &&
        incomingData().createdAt is timestamp &&
        (!('details' in incomingData()) || (incomingData().details is string && incomingData().details.size() <= 1000));

      allow read, list, update, delete: if isAdmin();
    }

    match /shippedApps/{appId} {
      allow read: if true;
      allow create: if isEmailVerified() && isValidId(appId) && incomingData().developerId == request.auth.uid;
      allow update, delete: if isOwner(existingData().developerId);
    }
  }
}
