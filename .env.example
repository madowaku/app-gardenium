# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Growth Agent model routing and local mock mode.
# Default structured suggestions use Flash-Lite for low latency and repeatable cost.
GROWTH_AGENT_MODEL="gemini-2.5-flash-lite"
# Stronger model for copy-heavy/final polish tasks. Override with the official model ID available in Google AI Studio / Vertex AI.
GROWTH_AGENT_STRONG_MODEL="gemini-3-flash-preview"
GROWTH_AGENT_COPY_MODEL="gemini-3-flash-preview"
AGENT_MOCK_MODE="true"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PUBLIC_SITE_URL: Canonical public website URL used for SEO, sitemap, canonical URLs, and OGP.
PUBLIC_SITE_URL="https://app-gardenium.com"

# STRIPE_SECRET_KEY: Required for Stripe billing integration.
# Users obtain this from the Stripe Dashboard.
STRIPE_SECRET_KEY=

# STRIPE_WEBHOOK_SECRET: Required to verify Stripe webhook signatures.
STRIPE_WEBHOOK_SECRET=

# STRIPE_SUCCESS_URL: Landing page after successful checkout.
STRIPE_SUCCESS_URL="http://localhost:3000/membership?payment=success"

# STRIPE_CANCEL_URL: Landing page after canceled checkout.
STRIPE_CANCEL_URL="http://localhost:3000/membership?payment=cancel"

# STRIPE_PORTAL_RETURN_URL: Where to return from customer portal.
STRIPE_PORTAL_RETURN_URL="http://localhost:3000/membership"

# STRIPE_SUPPORTER_PRICE_ID: Stripe Price ID for Supporter plan.
STRIPE_SUPPORTER_PRICE_ID=""

# STRIPE_PRO_PRICE_ID: Stripe Price ID for Pro plan.
STRIPE_PRO_PRICE_ID=""

# STRIPE_BOOST_SUPPORT_PRICE_ID: price_...
STRIPE_BOOST_SUPPORT_PRICE_ID=""

# STRIPE_EXTRA_ACTIVITY_REPORT_PRICE_ID: price_...
STRIPE_EXTRA_ACTIVITY_REPORT_PRICE_ID=""

# STRIPE_EXTRA_TESTER_RECRUITMENT_PRICE_ID: price_...
STRIPE_EXTRA_TESTER_RECRUITMENT_PRICE_ID=""
